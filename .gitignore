venv/
ENV/
env/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Testing
.tox/
.nox/
.coverage
htmlcov/
.pytest_cache/
coverage.xml
*.cover

# Jupyter Notebook
.ipynb_checkpoints

# Environment files
.env
.env.local
.env.*.local

# Logs
logs/
*.log

# OS files
.DS_Store
Thumbs.db

# Project specific
data/raw/
data/processed/
models/
*.pkl
*.joblib
*.h5
*.pt
*.pth

# MLflow
mlruns/
mlartifacts/

