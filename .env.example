# ============================================
# DataPilot AI Pro - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# ============================================

# ===========================================
# LLM CONFIGURATION - OpenAI GPT-4
# ===========================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# ===========================================
# VECTOR DATABASE - ChromaDB
# ===========================================
# Local persistent storage path for ChromaDB
CHROMADB_PATH=./chroma_store

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# Primary database for metadata / user data
DATABASE_URL=postgresql://datapilot:datapilot@localhost:5432/datapilot
REDIS_URL=redis://localhost:6379

# ===========================================
# MLFLOW CONFIGURATION
# ===========================================
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=datapilot-experiments

# ===========================================
# API CONFIGURATION
# ===========================================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# ===========================================
# STREAMLIT CONFIGURATION
# ===========================================
STREAMLIT_PORT=8501
